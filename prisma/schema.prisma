// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum WorkspaceTier {
  FREE
  UNLIMITED
}

enum WorkspaceRole {
  OWNER
  MEMBER
}

enum WorkspaceAccess {
  FULL
  READ
}

/// Parametric packaging discriminator for can/bottle SKUs (Plan 02 S3).
enum SkuShape {
  CAN
  BOTTLE
}

model Workspace {
  id        String        @id @default(cuid())
  name      String
  slug      String?       @unique
  tier      WorkspaceTier @default(FREE)
  stripeCustomerId         String?   @unique
  stripeSubscriptionId     String?   @unique
  stripeSubscriptionStatus String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  members         WorkspaceMember[]
  invitations     WorkspaceInvitation[]
  planograms      Planogram[]
  skus            SKU[]
  activeForUsers  User[]              @relation("UserActiveWorkspace")
}

model WorkspaceMember {
  id          String          @id @default(cuid())
  userId      String
  workspaceId String
  role        WorkspaceRole   @default(MEMBER)
  access      WorkspaceAccess @default(FULL)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
}

model WorkspaceInvitation {
  id            String          @id @default(cuid())
  token         String          @unique
  workspaceId   String
  createdById   String
  expiresAt     DateTime
  redeemedAt    DateTime?
  revokedAt     DateTime?
  defaultAccess WorkspaceAccess @default(FULL)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User      @relation("WorkspaceInvitationsCreated", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model SKU {
  id          String    @id @default(uuid())
  workspaceId String
  name        String
  sku         String
  /// Face-on width (mm) for the 2D engine; derived from packaging when set.
  width       Int
  /// Face-on height (mm) for the 2D engine; derived from packaging when set.
  height      Int
  /// Persisted display color (#rrggbb) used when imageUrl is missing.
  color       String
  imageUrl    String?
  /// Null = flat face-on SKU (width/height only). CAN | BOTTLE when parametric.
  shape       SkuShape?
  /// Shape-specific dims (mm / ml). Null when shape is null. Validated in app.
  packaging   Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  planogramItems PlanogramItem[]

  @@unique([workspaceId, sku])
  @@index([workspaceId])
}

model Planogram {
  id           String   @id @default(uuid())
  workspaceId  String
  name         String
  topClearance Int
  stackGap     Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspace Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  shelves   PlanogramShelf[]

  @@index([workspaceId])
}

model PlanogramShelf {
  id                 String   @id @default(uuid())
  planogramId        String
  index              Int
  minContentHeightMm Int      @default(500)
  minContentWidthMm  Int      @default(200)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  planogram           Planogram       @relation(fields: [planogramId], references: [id])
  planogramShelfItems PlanogramItem[]
}

model PlanogramItem {
  id               String   @id @default(uuid())
  planogramShelfId String
  skuId            String
  x                Int
  width            Int
  height           Int
  y                Int      @default(0)
  facingsWide      Int      @default(1)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  planogramShelf PlanogramShelf @relation(fields: [planogramShelfId], references: [id])
  sku            SKU            @relation(fields: [skuId], references: [id])

  @@index([planogramShelfId])
}

model User {
  id                 String    @id @default(cuid())
  name               String?
  email              String    @unique
  emailVerified      DateTime?
  image              String?
  passwordHash       String?
  /// Bumped on password change/reset; used to invalidate JWTs issued earlier.
  passwordChangedAt  DateTime?
  activeWorkspaceId  String?
  accounts           Account[]
  sessions           Session[]
  memberships        WorkspaceMember[]
  invitationsCreated WorkspaceInvitation[] @relation("WorkspaceInvitationsCreated")
  activeWorkspace    Workspace?            @relation("UserActiveWorkspace", fields: [activeWorkspaceId], references: [id], onDelete: SetNull)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([activeWorkspaceId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
