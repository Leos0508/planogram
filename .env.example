# PostgreSQL connection string (Neon, local Docker, etc.)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-random-secret"

# Optional: set in production for correct callback URLs (Vercel sets this automatically)
# AUTH_URL="https://your-app.vercel.app"

# Trust host header in CI/preview (required for 127.0.0.1 E2E and Vercel previews)
# AUTH_TRUST_HOST=true

# E2E tests — credentials for Playwright auth setup (CI/local)
# E2E_TEST_EMAIL="e2e@test.local"
# E2E_TEST_PASSWORD="testpassword123"
