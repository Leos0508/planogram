# PostgreSQL connection string (Neon, local Docker, etc.)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-random-secret"

# Optional: set in production for correct callback URLs (Vercel sets this automatically)
# AUTH_URL="https://your-app.vercel.app"

# Trust host header in CI/preview (required for 127.0.0.1 E2E and Vercel previews)
# AUTH_TRUST_HOST=true

# E2E tests — credentials for Playwright auth setup (CI/local)
# E2E_TEST_EMAIL="e2e@test.local"
# E2E_TEST_PASSWORD="testpassword123"

# Stripe Billing (S5) — test mode keys from https://dashboard.stripe.com/test/apikeys
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# STRIPE_PRICE_ID="price_..."
# Optional publishable key if client-side Stripe.js is needed later
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Optional app URL for Checkout/Portal return links (falls back to AUTH_URL / VERCEL_URL)
# NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Resend transactional email (S7) — https://resend.com/api-keys
# RESEND_API_KEY="re_..."
# Verified from address (domain must be verified in Resend, or use onboarding address locally)
# EMAIL_FROM="Planogram <noreply@yourdomain.com>"
# Setup: docs/EMAIL_SETUP.md · Smoke: docs/EMAIL_SMOKE_TEST.md

# Support contact (S8) — shown as mailto in auth footer / account hint
# SUPPORT_EMAIL="support@yourdomain.com"

# Vercel Blob (S6) — from Vercel Dashboard → Storage → Blob → .env.local
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Sentry (S10) — https://sentry.io · docs/SENTRY_SETUP.md
# Enabled in production only when a DSN is set
# NEXT_PUBLIC_SENTRY_DSN="https://<key>@o<org>.ingest.sentry.io/<project>"
# SENTRY_DSN="https://..."  # optional server alias
# Optional source maps on build:
# SENTRY_AUTH_TOKEN="sntrys_..."
# SENTRY_ORG="your-org-slug"
# SENTRY_PROJECT="planogram"

# Stripe live go-live (S10) — ops checklist: docs/STRIPE_LIVE_GO_LIVE.md
# Use sk_live_ / pk_live_ / live price + live webhook secret on Production only
